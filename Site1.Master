<body>

    <form runat="server" >
    <div class="page" style="width: 1000px">
        <div class="header" >
            <div class="title">
                <h1>
                   MAS Claims Payments
                </h1>
            </div>
            <div class="clear hideSkiplink notprint">
                <asp:Menu ID="Menu1" runat="server" CssClass="menu" EnableViewState="false" IncludeStyleBlock="false" Orientation="Horizontal">
                    <LevelMenuItemStyles>
                            <asp:MenuItemStyle CssClass=""/>
                                <asp:MenuItemStyle CssClass="subMenuStyle"/>
                        </LevelMenuItemStyles>
                    <Items >
                        <asp:MenuItem NavigateUrl="~/Home.aspx" Text="Home " Value="Home ">                            
                        </asp:MenuItem>
                        <asp:MenuItem NavigateUrl="~/ClaimEntry.aspx" Text="Claim Entry " Value="Claim Entry ">                            
                        </asp:MenuItem>
                        <asp:MenuItem NavigateUrl="~/VoucherCreation.aspx" Text="Voucher Creation" 
                            Value="Voucher Creation">                            
                        </asp:MenuItem>
                        <asp:MenuItem NavigateUrl="~/VoucherReprint.aspx" Text="Voucher Reprint" 
                            Value="Voucher Reprint">                            
                        </asp:MenuItem>
                        <asp:MenuItem NavigateUrl="~/VoucherAuthorization.aspx" Text="Voucher Authorization" 
                            Value="Voucher Authorization">                            
                        </asp:MenuItem>
                         <asp:MenuItem Text="Reports" Value="Reports">
                            <asp:MenuItem NavigateUrl="ClaimReport.aspx" 
                                Text="Claims Report" Value="Claims Report" >
                            </asp:MenuItem>
                        </asp:MenuItem>
                        <asp:MenuItem NavigateUrl="~/UploadData.aspx" Text="Upload Data" 
                            Value="Upload Data">                            
                        </asp:MenuItem>
                        <asp:MenuItem NavigateUrl="~/DeleteEmployees.aspx" Text="Delete Employees" 
                            Value="Delete Employees">                            
                        </asp:MenuItem>
                        
                    </Items>
                </asp:Menu>
            </div>
        </div>
        <div class="main">
            <asp:ContentPlaceHolder ID="MainContent" runat="server"/>
        </div>
        <div class="clear">
        </div>
    </div>
    <div class="footer">
        
    </div>
    </form>
</body>

    
