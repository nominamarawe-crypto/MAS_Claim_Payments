                <td style="width: 14px; height: 21px; background-color: #eaf0cb">
                </td>
            </tr>
            <tr>
                <td style="width: 21px">
                </td>
                <td colspan="5" style="text-align: center">
                    <strong>Sri Lanka Insurance</strong></td>
                <td style="width: 14px">
                </td>
            </tr>
            <tr>
                <td style="width: 21px">
                </td>
                <td colspan="5">
                    <strong><span style="font-family: Trebuchet MS">Old Claims Details</span></strong></td>
