/// <summary>
/// Summary description for CompanyVouFields
/// </summary>
/// 
[Serializable()]
public class CompanyVouFields
{
    private long polno;
    private string payeenam, clmtyp, mos;
    private double share;

	public CompanyVouFields()
	{
		
	}

    public long Polno
    {
        get { return polno; }
        set { polno = value; }
    }
    public string Payeenam
    {
        get { return payeenam; }
        set { payeenam = value; }
    }
    public double Share
    {
        get { return share; }
        set { share = value; }
    }
    public string Clmtyp
    {
        get { return clmtyp; }
        set { clmtyp = value; }
    }
    public string Mos
    {
        get { return mos; }
        set { mos = value; }
    }
}
