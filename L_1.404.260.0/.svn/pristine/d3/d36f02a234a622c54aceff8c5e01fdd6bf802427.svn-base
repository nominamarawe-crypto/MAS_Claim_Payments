using System;
using System.Data;
using System.Configuration;
using System.Web;
using System.Web.Security;
using System.Web.UI;
using System.Web.UI.WebControls;
using System.Web.UI.WebControls.WebParts;
using System.Web.UI.HtmlControls;

[Serializable()]
public class vouPrintSLICFields
{
    private string slicvouno = "";
    private string reason = "";
    private double slicamount = 0;
    private string accode = "";

    public vouPrintSLICFields(string theSLICVouno, string theReason, double theSlicamount, string theAccode)
    {
        this.slicvouno = theSLICVouno;
        this.reason = theReason;
        this.slicamount = theSlicamount;
        this.accode = theAccode;
    }

    public string SLICVouno
    {
        get { return this.slicvouno; }
        set { this.slicvouno = value; }
    }
    public string Reason
    {
        get { return this.reason; }
        set { this.reason = value; }
    }
    public double Slicamount
    {
        get { return this.slicamount; }
        set { this.slicamount = value; }
    }
    public string Accode
    {
        get { return this.accode; }
        set { this.accode = value; }

    }
}
    
