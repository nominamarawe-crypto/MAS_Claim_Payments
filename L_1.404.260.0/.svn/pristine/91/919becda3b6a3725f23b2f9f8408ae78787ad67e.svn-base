<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">

<html xmlns="http://www.w3.org/1999/xhtml" >
<head runat="server">
    <title>SriLanka Insurance - Death Claims</title>
    <script src="JavaScript/FormValidation.js"  type="text/javascript"  language="javascript"></script>
    
    <script type="text/javascript">
        
     function test(source, arguments)
    {
    	    	
     if (!IsNumeric(arguments.Value))
            {arguments.IsValid = false;}          
              
     else
            {arguments.IsValid = true;}
    }   
    
<!--
function MM_goToURL() { //v3.0
  var i, args=MM_goToURL.arguments; document.MM_returnValue = false;
  for (i=0; i<(args.length-1); i+=2) eval(args[i]+".location='"+args[i+1]+"'");
}
//-->
 
</script>
</head>
<body style="font-size: 12pt">
    <form id="form1" runat="server">
    <div style="text-align: center">
        <span style="font-family: Trebuchet MS"><strong>
        </strong></span>
        <table style="width: 673px; font-weight: bold; font-size: 10pt; font-family: 'Trebuchet MS';">
            <tr>
                <td colspan="5" style="height: 18px; background-color: whitesmoke">
                </td>
            </tr>
            <tr>
                <td style="height: 18px;" colspan="5">
                    <span style="font-size: 14pt">
            Sri Lanka Insurance<br />
                    </span><span style="font-size: 12pt">Legal Hieres</span></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px; background-color: #f0f0f0;">
                </td>
                <td style="width: 80px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 75px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 64px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 123px; height: 18px; background-color: #f0f0f0; text-align: center">
                    <span style="color: #0000cc">YES?</span></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px;">
                </td>
                <td colspan="3" style="height: 18px; text-align: left">
                    At least a single nominee lives</td>
                <td style="width: 123px; height: 18px; text-align: left">
                    <asp:CheckBox ID="chkNomLive" runat="server" /></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px; background-color: #f0f0f0;">
                </td>
                <td style="width: 80px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 75px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 64px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 123px; height: 18px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px;">
                </td>
                <td style="height: 18px; text-align: left" colspan="3">
                    Was the deceased Married</td>
                <td style="width: 123px; height: 18px; text-align: left">
                    <asp:CheckBox ID="chkMarried" runat="server" /></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px; background-color: #f0f0f0;">
                </td>
                <td style="width: 80px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 75px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 64px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 123px; height: 18px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px;">
                </td>
                <td style="height: 18px; text-align: left" colspan="3">
                    If Married is the Spouce Alive at Present</td>
                <td style="width: 123px; height: 18px; text-align: left;"><asp:CheckBox ID="chkSpAl" runat="server" /></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px; background-color: #f0f0f0;">
                </td>
                <td style="width: 80px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 75px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 64px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 123px; height: 18px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px;">
                </td>
                <td style="height: 18px; text-align: left;" colspan="3">
                    Is the deceased's Mother Alive</td>
                <td style="width: 123px; height: 18px; text-align: left;"><asp:CheckBox ID="chkMthAl" runat="server" /></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px; background-color: #f0f0f0;">
                </td>
                <td style="width: 80px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 75px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 64px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 123px; height: 18px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px;">
                </td>
                <td style="height: 18px; text-align: left;" colspan="3">
                    Is the deceased's Father Alive</td>
                <td style="width: 123px; height: 18px; text-align: left;"><asp:CheckBox ID="chkFthAl" runat="server" /></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 19px; background-color: #f0f0f0;">
                </td>
                <td style="width: 80px; height: 19px; background-color: #f0f0f0">
                </td>
                <td style="width: 75px; height: 19px; background-color: #f0f0f0">
                </td>
                <td style="width: 64px; height: 19px; background-color: #f0f0f0">
                </td>
                <td style="width: 123px; height: 19px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px;">
                </td>
                <td style="height: 18px; text-align: left" colspan="3">
                    Does the deceased have any Living Children</td>
                <td style="width: 123px; height: 18px; text-align: left;"><asp:CheckBox ID="chkChildYN" runat="server" /></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px; background-color: #f0f0f0;">
                </td>
                <td style="width: 80px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 75px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 64px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 123px; height: 18px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px;">
                </td>
                <td style="height: 18px; text-align: left" colspan="3">
                    If Yes How Many</td>
                <td style="width: 123px; height: 18px; text-align: left;">
                    <asp:TextBox ID="txtChildrenNum" runat="server" MaxLength="2" Width="61px">0</asp:TextBox></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px; background-color: #f0f0f0;">
                </td>
                <td style="height: 18px; background-color: #f0f0f0; text-align: left;" colspan="3">
                    <asp:CustomValidator ID="CustomValidator1" runat="server" ClientValidationFunction="test"
                        ControlToValidate="txtChildrenNum" ErrorMessage="Please Enter a Number" Width="343px"></asp:CustomValidator></td>
                <td style="width: 123px; height: 18px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px;">
                </td>
                <td style="height: 18px; text-align: left;" colspan="3">
                    Does the deceased have any Living Brothers and/or Sisters</td>
                <td style="width: 123px; height: 18px; text-align: left;"><asp:CheckBox ID="chkBroYn" runat="server" /></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px; background-color: #f0f0f0;">
                </td>
                <td style="height: 18px; background-color: #f0f0f0; text-align: left;" colspan="3">
                </td>
                <td style="width: 123px; height: 18px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px;">
                </td>
                <td style="height: 18px; text-align: left;" colspan="3">
                    If Yes How Many (All Brothes and Sisters)</td>
                <td style="width: 123px; height: 18px; text-align: left;">
                    <asp:TextBox ID="txtBroSysNum" runat="server" MaxLength="2" Width="61px">0</asp:TextBox></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px; background-color: #f0f0f0;">
                </td>
                <td style="height: 18px; background-color: #f0f0f0; text-align: left;" colspan="3">
                    <asp:CustomValidator ID="CustomValidator2" runat="server" ClientValidationFunction="test"
                        ControlToValidate="txtBroSysNum" ErrorMessage="Please Enter a Number" Width="343px"></asp:CustomValidator></td>
                <td style="width: 123px; height: 18px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="height: 18px;" colspan="5">
                    <asp:CustomValidator ID="CV" runat="server"></asp:CustomValidator></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px; background-color: #f0f0f0;">
                </td>
                <td style="width: 80px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 75px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 64px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 123px; height: 18px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="height: 18px;" colspan="5">
                    <asp:Button ID="btnUpd" runat="server" Font-Bold="True" Font-Names="Trebuchet MS"
                        PostBackUrl="~/Lhupdate001.aspx" Text="Update/Delete" Visible="False" OnClick="btnUpd_Click" />
                    <asp:Button ID="btnSubmit" runat="server" Text=" Submit " OnClick="btnSubmit_Click" PostBackUrl="~/legalHieres002.aspx" Font-Bold="True" Font-Names="Trebuchet MS" />
                    <asp:Button ID="btnexit" runat="server" Text="  Exit  " OnClientClick="self.close()" Font-Bold="True" Font-Names="Trebuchet MS" /></td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px; background-color: #f0f0f0;">
                </td>
                <td style="width: 80px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 75px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 64px; height: 18px; background-color: #f0f0f0">
                </td>
                <td style="width: 123px; height: 18px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 17px; height: 18px;">
                </td>
                <td style="width: 80px; height: 18px">
                </td>
                <td style="width: 75px; height: 18px">
                </td>
                <td style="width: 64px; height: 18px">
                </td>
                <td style="width: 123px; height: 18px">
                </td>
            </tr>
        </table>
    
    </div>
    </form>
</body>
</html>
