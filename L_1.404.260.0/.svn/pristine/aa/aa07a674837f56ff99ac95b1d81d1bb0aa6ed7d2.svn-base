using System;
using System.Data;
using System.Configuration;
using System.Web;
using System.Web.Security;
using System.Web.UI;
using System.Web.UI.WebControls;
using System.Web.UI.WebControls.WebParts;
using System.Web.UI.HtmlControls;

[Serializable()]
public class remainderValSet
{
    private long polno;
    private string type;
    private int sentdate;
    private string remarks;

	public remainderValSet(long polnoeka, string typeeka, int sentdateeka, string rema)
	{
        this.polno = polnoeka;
        this.type = typeeka;
        this.sentdate = sentdateeka;
        this.remarks = rema;
	}
    public long Polno {
        get { return polno;}
        set { polno = value; }
    }
    public string Type{
        get { return type; }
        set { type = value; }
    }
    public int Sentdate{
        get { return sentdate; }
        set { sentdate = value; }
    }
    public string Remarks{
        get { return remarks; }
        set { remarks = value; }
    }
}
