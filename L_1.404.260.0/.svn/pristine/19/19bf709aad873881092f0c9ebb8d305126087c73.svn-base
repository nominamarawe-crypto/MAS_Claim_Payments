<%@ Page Language="C#" AutoEventWireup="true" CodeFile="PolCont002.aspx.cs" Inherits="PolCont002" %>
<%@ PreviousPageType VirtualPath="~/PolCont001.aspx" %>
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">

<html xmlns="http://www.w3.org/1999/xhtml" >
<head runat="server">
    <title>Untitled Page</title>
</head>
<body>
    <form id="form1" runat="server">
    <div style="text-align: center">
        <br />
        <table style="font-size: 10pt; width: 700px; font-family: 'Trebuchet MS'">
            <tr>
                <td style="width: 114px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 112px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 117px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 100px; height: 15px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td colspan="4" style="height: 15px">
                    <strong><span style="font-size: 11pt">Policy Continuation</span></strong></td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 112px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 117px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 100px; height: 15px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; text-align: left">
                    <strong>Policy Number</strong></td>
                <td style="width: 112px; height: 15px; text-align: left">
                    <asp:Literal ID="litpol" runat="server"></asp:Literal></td>
                <td style="width: 117px; height: 15px; text-align: left">
                    <strong>
                    Claim Number</strong></td>
                <td style="width: 100px; height: 15px; text-align: left">
                    <asp:Literal ID="litclm" runat="server"></asp:Literal></td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 112px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 117px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 100px; height: 15px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; text-align: left">
                    <strong style="text-align: left">
                    Date of Commencement</strong></td>
                <td style="width: 112px; height: 15px; text-align: left">
                    <asp:Literal ID="litcomdt" runat="server"></asp:Literal></td>
                <td style="width: 117px; height: 15px">
                </td>
                <td style="width: 100px; height: 15px">
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 112px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 117px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 100px; height: 15px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; text-align: left">
                    <strong>
                    Deceased Life </strong>
                </td>
                <td style="width: 112px; height: 15px; text-align: left">
                    <asp:Literal ID="litliftype" runat="server"></asp:Literal></td>
                <td style="width: 117px; height: 15px; text-align: left">
                    <strong>
                    Date of Death</strong></td>
                <td style="width: 100px; height: 15px; text-align: left">
                    <asp:Literal ID="litdthdt" runat="server"></asp:Literal></td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 112px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 117px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 100px; height: 15px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 10px; text-align: left">
                    <strong>
                    Name Of Deceased</strong></td>
                <td colspan="3" style="height: 10px; text-align: left">
                    <asp:Literal ID="litnmdecs" runat="server"></asp:Literal></td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 112px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 117px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 100px; height: 15px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 10px; text-align: left">
                    <strong>Table/Term</strong></td>
                <td style="width: 112px; height: 10px; text-align: left">
                    <asp:TextBox ID="txttbl" runat="server" Enabled="False" MaxLength="2" Width="31px"></asp:TextBox>/<asp:TextBox
                        ID="txttrm" runat="server" Enabled="False" MaxLength="2" Width="31px"></asp:TextBox></td>
                <td style="width: 117px; height: 10px; text-align: left;">
                    <strong>Mode</strong></td>
                <td style="width: 100px; height: 10px; text-align: left;">
                    <asp:TextBox ID="txtmd" runat="server" Enabled="False" MaxLength="1" Width="39px"></asp:TextBox></td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 112px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 117px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 100px; height: 15px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 10px; text-align: left">
                    <strong>Current Premium</strong></td>
                <td style="width: 112px; height: 10px; text-align: left">
                    <asp:TextBox ID="txtcurrprm" runat="server" Width="95px"></asp:TextBox></td>
                <td style="width: 117px; height: 10px; text-align: left;">
                    <strong>Adjusted Premium</strong></td>
                <td style="width: 100px; height: 10px; text-align: left;">
                    <asp:TextBox ID="txtadjprm" runat="server" Width="97px"></asp:TextBox></td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 112px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 117px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 100px; height: 15px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 10px; text-align: left">
                    <strong>Next Due Yr/Mn</strong></td>
                <td style="width: 112px; height: 10px; text-align: left">
                    <asp:TextBox ID="txtdueyrmn" runat="server" Height="15px" MaxLength="6" Width="63px">0</asp:TextBox>
                    (yyyymm)</td>
                <td style="width: 117px; height: 10px">
                </td>
                <td style="width: 100px; height: 10px">
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 112px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 117px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 100px; height: 15px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 10px; text-align: left">
                </td>
                <td style="height: 10px; text-align: left" colspan="3">
                    <asp:Table ID="Table1" runat="server" Width="331px">
                    </asp:Table>
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 112px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 117px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 100px; height: 15px; background-color: #f0f0f0">
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 10px; text-align: left">
                </td>
                <td style="width: 112px; height: 10px; text-align: left">
                </td>
                <td style="width: 117px; height: 10px">
                </td>
                <td style="width: 100px; height: 10px">
                </td>
            </tr>
            <tr>
                <td style="width: 114px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 112px; height: 15px; background-color: #f0f0f0">
                    <asp:Button ID="Button1" runat="server" OnClick="Button1_Click" Text="Button" /></td>
                <td style="width: 117px; height: 15px; background-color: #f0f0f0">
                </td>
                <td style="width: 100px; height: 15px; background-color: #f0f0f0">
                </td>
            </tr>
        </table>
    
    </div>
    </form>
</body>
</html>
